#!/usr/bin/env bash
# cockpit-send — resume a Claude session as a cockpit pane.
#
#   cockpit-send <id|prefix> [--cwd PATH]
#
# If a cockpit grid is running: split a new pane onto the session, stamp it so
# the poller tracks it, and re-tile. If not: append it to a pending queue that
# `cockpit --santa` drains into a fresh grid when the picker TUI exits.
#
# This is the bridge that lets santa's TUI "resume" feed cockpit instead
# of opening a wt.exe tab — see shim/wt.exe.
set -uo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"; source "$HERE/lib.sh"
TMUX=${COCKPIT_TMUX:-"tmux -L cockpit"}
PENDING="${TMPDIR:-/tmp}/cockpit-pending.${COCKPIT_SESSION}"
LOG="${TMPDIR:-/tmp}/cockpit-send.log"
log() { printf '%s  %s\n' "$(date '+%H:%M:%S')" "$*" >> "$LOG" 2>/dev/null || true; }

id=""; cwd=""; agent=""
while [[ $# -gt 0 ]]; do case "$1" in
  --cwd) cwd="${2:-}"; shift;; --agent) agent="${2:-}"; shift;; *) id="$1";; esac; shift; done
log "invoked: id='$id' cwd-arg='$cwd' agent='$agent' COCKPIT_TMUX='${COCKPIT_TMUX:-<unset>}'"
[[ -n "$id" ]] || { echo "usage: cockpit-send <id|prefix> [--cwd PATH] [--agent claude|codex]" >&2; log "ABORT: no id"; exit 2; }

# resolve agent + full id + cwd + title. Claude resolves via santa's DB (handles
# prefixes); otherwise try a Codex rollout; default claude.
title=""
if [[ "$agent" != codex ]]; then
  row=$(sqlite3 -separator $'\t' "$SANTA_DB" \
    "SELECT id, coalesce(cwd,''), coalesce(nullif(summary_title,''), substr(first_user_text,1,80),'') \
     FROM sessions WHERE id LIKE '${id}%' LIMIT 1;" 2>/dev/null)
  if [[ -n "$row" ]]; then
    IFS=$'\t' read -r fid fcwd ftitle <<< "$row"; id="$fid"
    # santa's DB now indexes codex sessions too, so "found in DB" no longer implies
    # claude. Trust the recorded provider; a pre-migration DB lacks the column, so
    # the query errors → empty → claude (correct: codex isn't in an old DB anyway).
    prov=$(sqlite3 "$SANTA_DB" "SELECT coalesce(provider,'claude-code') FROM sessions WHERE id='$fid';" 2>/dev/null)
    [[ "$prov" == codex ]] && agent=codex || agent=claude
    [[ -z "$cwd" ]] && cwd="$fcwd"; title="$ftitle"
  fi
fi
if [[ -z "$agent" || "$agent" == codex ]]; then
  cj=$(codex_transcript "$id")
  if [[ -n "$cj" ]]; then
    agent=codex
    [[ -z "$cwd" ]] && cwd=$(jq -r 'select(.type=="session_meta")|.payload.cwd // empty' <<<"$(head -1 "$cj")" 2>/dev/null)
    [[ -z "$title" ]] && title=$(jq -rc 'select(.payload.type=="user_message")|.payload.message' "$cj" 2>/dev/null | grep -v '^$' | head -1 | cut -c1-100)
  fi
fi
[[ -n "$agent" ]] || agent=claude
[[ -z "$cwd" && "$agent" == claude ]] && { j=$(session_jsonl "$id" ""); [[ -n "$j" ]] && cwd=$(jq -r 'select(.cwd)|.cwd' "$j" 2>/dev/null | head -1); }
[[ -n "$cwd" ]] || cwd="$HOME"
[[ -n "$title" ]] || title="${id:0:8}"
log "resolved: agent=$agent id=$id cwd=$cwd"

if ! $TMUX has-session -t "$COCKPIT_SESSION" 2>/dev/null; then
  printf '%s\t%s\t%s\t%s\n' "$id" "$cwd" "$title" "$agent" >> "$PENDING"   # queue for cold build
  exit 0
fi

if session_is_running_agent "$agent" "$id"; then
  $TMUX display-message "cockpit: ${id:0:8} is already live — not duplicating"
  exit 0
fi

cmd=$(agent_resume_inner "$agent" "$id" "$cwd")
W=$(cockpit_cur_window)   # land in the workspace you're viewing
# reuse a bare untracked shell (e.g. a freshly-created workspace) if it's active
act=$($TMUX display -p -t "$W" '#{pane_id}' 2>/dev/null)
actsid=$($TMUX show -p -t "$act" @session_id 2>/dev/null | awk '{print $2}')
if [[ -z "$actsid" && -n "$act" ]]; then
  pane="$act"; $TMUX respawn-pane -k -t "$pane" "bash -lc $(printf %q "$cmd")"
else
  pane=$($TMUX split-window -t "$W" -P -F '#{pane_id}' "bash -lc $(printf %q "$cmd")" 2>/dev/null) \
    || { $TMUX display-message "cockpit: no room for another pane at this width"; exit 0; }
fi
$TMUX set -p -t "$pane" @session_id "$id"
$TMUX set -p -t "$pane" @cwd "$cwd"
$TMUX set -p -t "$pane" @label "$title"      # full; border truncates to width
$TMUX set -p -t "$pane" @agent "$agent"
$TMUX set -p -t "$pane" @badge "starting"
$TMUX select-layout -t "$W" "$COCKPIT_LAYOUT" 2>/dev/null
$TMUX display-message "cockpit: + ${title:0:40}"
