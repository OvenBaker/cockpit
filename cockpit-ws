#!/usr/bin/env bash
# cockpit-ws — workspace (window) operations with a RECOVERABLE soft-close.
# Killing a workspace tears down its panes (and their Claude sessions), so
# instead of doing it immediately we mark it, switch away, and reap it after a
# grace period — leaving a window to hit Alt-u and get it back.
#
#   cockpit-ws close            mark the current workspace; it dies in ~10s
#   cockpit-ws undo             cancel the most-recent pending close
#   cockpit-ws reap <win> <tok> (internal) kill <win> after the grace iff still pending
set -uo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"; source "$HERE/lib.sh"
TMUX=${COCKPIT_TMUX:-"tmux -L cockpit"}
GRACE="${COCKPIT_CLOSE_GRACE:-10}"

wopt() { $TMUX show -wqv -t "$1" "$2" 2>/dev/null; }   # window option (quiet, value-only)

case "${1:-close}" in
  close)
    win=$($TMUX display -p -t "$COCKPIT_SESSION" '#{window_id}')
    n=$($TMUX list-windows -t "$COCKPIT_SESSION" -F x 2>/dev/null | wc -l)
    if (( n <= 1 )); then
      $TMUX display-message "cockpit: can't close the last workspace (cockpit --kill to exit)"; exit 0
    fi
    [[ -n "$(wopt "$win" @closing)" ]] && exit 0          # already counting down
    name=$($TMUX display -p -t "$win" '#{window_name}')
    tok="$(date +%s)-$$"
    $TMUX set -w -t "$win" @origname "$name"
    $TMUX set -w -t "$win" @closing  "$tok"
    $TMUX rename-window -t "$win" "✗ $name"               # visible cue on the tab
    $TMUX set -g @undo_kind ws; $TMUX set -g @undo_win "$win"; $TMUX set -g @undo_tok "$tok"
    $TMUX previous-window -t "$COCKPIT_SESSION" 2>/dev/null || true   # get it out of view
    $TMUX display-message "closing '$name' in ${GRACE}s — Alt-u to undo"
    setsid nohup "$HERE/cockpit-ws" reap "$win" "$tok" >/dev/null 2>&1 &
    ;;
  reap)
    win="${2:-}"; tok="${3:-}"
    sleep "$GRACE"
    # only kill if it's STILL the same pending close (not undone, not re-closed)
    [[ -n "$tok" && "$(wopt "$win" @closing)" == "$tok" ]] && $TMUX kill-window -t "$win" 2>/dev/null
    ;;
  undo)
    win=$($TMUX show -gqv @undo_win 2>/dev/null); tok=$($TMUX show -gqv @undo_tok 2>/dev/null)
    if [[ -z "$win" || "$(wopt "$win" @closing)" != "$tok" ]]; then
      $TMUX display-message "cockpit: nothing to undo"; exit 0
    fi
    name=$(wopt "$win" @origname)
    $TMUX set -w -t "$win" @closing ""
    $TMUX rename-window -t "$win" "${name:-workspace}"
    $TMUX select-window -t "$win"
    $TMUX display-message "recovered '${name}'"
    ;;
  *) echo "usage: cockpit-ws {close|undo}" >&2; exit 2;;
esac
