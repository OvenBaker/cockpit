#!/usr/bin/env bash
# cockpit — a tmux control surface for your most-recent unfinished Claude sessions.
#
#   cockpit              pick sessions interactively, build the grid, attach
#                        (if a cockpit is already running, attaches to it)
#   cockpit --santa      pick sessions in santa-claude's TUI (resume → cockpit)
#   cockpit --rebuild    tear down a running cockpit, then build a fresh one
#   cockpit --auto       skip the picker: just open the top -n sessions
#   cockpit --list       dry run: show the candidate sessions
#   cockpit -n N         default selection / --auto pane count (default 5)
#   cockpit --attach     just attach to an existing cockpit
#   cockpit --kill       tear down the cockpit server
#
# Workspaces = tmux windows. Builds two: 'work' (your picked sessions) and an
# empty 'scratch' for quick/transient ones. The status bar shows them as tabs,
# tinted by each workspace's most-urgent pane.
#
# Frame: titled bordered panes, colored by live state (green=working,
# blue=just-finished, red=needs-input, dim=idle; active pane = yellow border).
# Keys (no prefix needed):
#   Alt-←/→   switch workspace    Alt-w  new workspace
#   Alt-W     close workspace (10s timer)          Alt-u  undo a close
#   Alt-1..9  jump to pane        Alt-Tab  next attention-worthy pane
#   Alt-z     zoom toggle         Alt-i    collapse/restore idle panes
#   Alt-r     retarget pane → pick a dormant session (popup, list refreshed live)
#   Alt-n     add a pane: resume a session         Alt-N  new session in a cwd
#   Alt-m     move pane → workspace (Alt-S-←/→ shove)   Alt-x  remove the active pane
#   Alt-s     browse santa-claude's TUI; resume there sends the session here
#   Alt-/ , Alt-h , Alt-?     show the key reference popup
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"; source "$HERE/lib.sh"
TMUX="tmux -L cockpit"
N=5; MODE=build; AUTO=0; REBUILD=0; SANTA=0
while [[ $# -gt 0 ]]; do case "$1" in
  --list|-l) MODE=list;; --attach|-a) MODE=attach;; --kill) MODE=kill;;
  --rebuild) REBUILD=1;; --auto) AUTO=1;; --santa) SANTA=1;; -n) N="$2"; shift;;
  *) echo "unknown arg: $1" >&2; exit 2;; esac; shift; done
PENDING="${TMPDIR:-/tmp}/cockpit-pending.${COCKPIT_SESSION}"

case "$MODE" in
  kill)   pkill -f "$HERE/cockpit-poller" 2>/dev/null || true
          $TMUX kill-server 2>/dev/null && echo "cockpit killed" || echo "no cockpit running"; exit 0;;
  attach) exec $TMUX attach -t "$COCKPIT_SESSION";;
  list)
    printf '%-10s %-30s %s\n' "SESSION" "CWD" "TITLE"
    cockpit_candidates "$N" | while IFS=$'\t' read -r id cwd title; do
      printf '%-10s %-30s %s\n' "${id:0:8}" "${cwd/#$HOME/\~}" "$title"
    done; exit 0;;
esac

# --rebuild: tear down any existing cockpit first, so we always re-pick from
# scratch (and pick up the latest keybinds/chrome).
if [[ "$REBUILD" == 1 ]] && $TMUX has-session -t "$COCKPIT_SESSION" 2>/dev/null; then
  echo "cockpit: tearing down the running grid to rebuild…" >&2
  $TMUX kill-server 2>/dev/null || true
fi

# already running? With --santa, open the picker TUI first (its resume key adds
# panes live via the wt.exe shim), then attach. Otherwise just attach.
if $TMUX has-session -t "$COCKPIT_SESSION" 2>/dev/null; then
  if [[ "$SANTA" == 1 ]]; then
    echo "cockpit: opening santa-claude — resume sends sessions into the grid…" >&2
    SANTA_RESUME_CMD="$HERE/cockpit-send" SANTA_RESUME_LABEL=cockpit PATH="$HERE/shim:$PATH" \
      COCKPIT_SEND="$HERE/cockpit-send" COCKPIT_TMUX="$TMUX" santa-claude tui || true
    exec $TMUX attach -t "$COCKPIT_SESSION"
  fi
  echo "cockpit already running — attaching. ( --rebuild to re-pick · --santa to browse · --kill to tear down )" >&2
  exec $TMUX attach -t "$COCKPIT_SESSION"
fi

# choose which sessions to open.
#   --santa : browse in santa-claude's TUI; its resume key queues sessions (via
#             the wt.exe shim → cockpit-send), and we build from the queue on exit.
#   --auto / non-tty : top-N, no prompt.
#   default : the numbered picker (set pane count, skip stale ones).
if [[ "$SANTA" == 1 ]]; then
  : > "$PENDING"
  echo "cockpit: browse in santa-claude, hit resume on the sessions you want, then quit the TUI." >&2
  SANTA_RESUME_CMD="$HERE/cockpit-send" SANTA_RESUME_LABEL=cockpit PATH="$HERE/shim:$PATH" \
    COCKPIT_SEND="$HERE/cockpit-send" COCKPIT_TMUX="$TMUX" santa-claude tui || true
  mapfile -t CAND < <(awk -F'\t' 'NF>=2 && !seen[$1]++ {print}' "$PENDING" 2>/dev/null)
  [[ ${#CAND[@]} -gt 0 ]] || { echo "no sessions chosen in santa-claude"; exit 0; }
elif [[ "$AUTO" == 1 || ! -t 0 || ! -t 1 ]]; then
  mapfile -t CAND < <(cockpit_candidates "$N")
else
  mapfile -t CAND < <(COCKPIT_DEFAULT_N="$N" "$HERE/cockpit-pick" startup)
fi
[[ ${#CAND[@]} -gt 0 ]] || { echo "no sessions selected"; exit 0; }

# server-wide look & feel + keybinds. Applied AFTER the first session exists:
# tmux ≥3.4 lets an empty server (start-server with no sessions) exit
# immediately, so any `set -g`/`bind` issued before the first new-session dies
# with "no server running" and set -e kills the script.
apply_chrome() {
  $TMUX set -g pane-border-status top
  $TMUX set -g pane-border-lines heavy
  # label hugs the left, status+time hug the right; the heavy line fills the gap.
  # This way a long label only eats into the middle, never the badge.
  $TMUX set -g pane-border-format '#[align=left] #{?@label,#{@label},#{pane_index}} #[align=right] #{?@badge,#{@badge},…} '
  $TMUX set -g pane-border-style 'fg=colour240'
  # active border = yellow, deliberately distinct from the state colours so the
  # focused pane never looks like "just-finished" (which is blue).
  $TMUX set -g pane-active-border-style 'fg=colour220,bold'
  $TMUX set -g mouse on
  $TMUX set -g status-style 'bg=colour234,fg=colour250'
  $TMUX set -g status-left  ' cockpit '
  $TMUX set -g status-right '#[fg=colour39]#{@active_count} active#[default]  #{@finished_count} done  #{@idle_count} idle '
  $TMUX set -g status-right-length 60
  # workspaces = windows. Each tab is named, and the poller tints the name by the
  # workspace's most-urgent pane (@ws_badge) so a needs-input session glows even
  # when you're looking elsewhere. The current workspace gets a highlighted slab.
  $TMUX set -g status-justify left
  $TMUX set -g window-status-separator ''
  $TMUX set -g window-status-style 'fg=colour245'
  $TMUX set -g window-status-current-style 'bg=colour238,fg=colour255,bold'
  $TMUX set -g window-status-format         ' #{?@ws_badge,#{@ws_badge},}#W#[default] '
  $TMUX set -g window-status-current-format ' #{?@ws_badge,#{@ws_badge},}#W '
  # keybinds (no-prefix Alt-…).
  # Server ops (select-pane, layout, kill) go via run-shell. But popups/menus
  # need a client, which run-shell has NOT — so the choosers/help are bound
  # DIRECTLY to display-popup (the keypress supplies the client). #{pane_id}
  # is expanded to the pane that was focused when the key was pressed.
  for i in 1 2 3 4 5 6 7 8 9; do $TMUX bind -n "M-$i" select-pane -t "$i" 2>/dev/null || true; done
  $TMUX bind -n M-Tab run-shell "$HERE/cockpit-next"
  $TMUX bind -n M-z   resize-pane -Z
  $TMUX bind -n M-i   run-shell "$HERE/cockpit-toggle-idle"
  $TMUX bind -n M-r   display-popup -E -w 90% -h 80% "$HERE/cockpit-pick retarget #{pane_id}"
  $TMUX bind -n M-n   display-popup -E -w 90% -h 80% "$HERE/cockpit-pick add"
  $TMUX bind -n M-N   display-popup -E -w 90% -h 80% "$HERE/cockpit-pick new"
  # browse in santa-claude's TUI; its resume key drops the session into the grid
  $TMUX bind -n M-s   display-popup -E -w 95% -h 90% \
    "SANTA_RESUME_CMD=$HERE/cockpit-send SANTA_RESUME_LABEL=cockpit PATH=$HERE/shim:\$PATH COCKPIT_SEND=$HERE/cockpit-send COCKPIT_TMUX='$TMUX' santa-claude tui"
  $TMUX bind -n M-x   run-shell "$HERE/cockpit-pane remove"
  # move the active pane to another workspace: Alt-m to pick/create, Alt-Shift-←/→ to shove
  $TMUX bind -n M-m       display-popup -E -w 70 -h 24 "$HERE/cockpit-move pick #{pane_id}"
  $TMUX bind -n M-S-Left  run-shell "$HERE/cockpit-move prev"
  $TMUX bind -n M-S-Right run-shell "$HERE/cockpit-move next"
  # workspaces: switch with Alt-←/→, create with Alt-w, close with Alt-W
  $TMUX bind -n M-Left  previous-window
  $TMUX bind -n M-Right next-window
  $TMUX bind -n M-w command-prompt -p "new workspace:" "new-window -n '%%' 'bash -l'"
  # close a workspace on a 10s recoverable timer (Alt-u to undo); also reroute
  # the default prefix kill-window (C-b &) through the same soft-close.
  $TMUX bind -n M-W run-shell "$HERE/cockpit-ws close"
  $TMUX bind -n M-u run-shell "$HERE/cockpit-ws undo"
  $TMUX bind '&'    run-shell "$HERE/cockpit-ws close"
  $TMUX bind -n M-/   display-popup -E -w 64 -h 42 "$HERE/cockpit-help show"
  $TMUX bind -n M-h   display-popup -E -w 64 -h 42 "$HERE/cockpit-help show"
  $TMUX bind -n M-?   display-popup -E -w 64 -h 42 "$HERE/cockpit-help show"
}

# build the 'work' workspace — first session opens the window, rest split + tile.
# Capture each pane's stable pane_id (%N) so stamping survives re-layout.
first=1
for row in "${CAND[@]}"; do
  IFS=$'\t' read -r id cwd title <<< "$row"
  cmd="cd $(printf %q "$cwd") && exec claude --resume $id"
  if (( first )); then
    pane=$($TMUX new-session -d -P -F '#{pane_id}' -s "$COCKPIT_SESSION" -n work -x 320 -y 80 "bash -lc $(printf %q "$cmd")")
    apply_chrome   # server now alive — safe to set globals/keybinds
    first=0
  else
    pane=$($TMUX split-window -t "$COCKPIT_SESSION:work" -P -F '#{pane_id}' "bash -lc $(printf %q "$cmd")")
    $TMUX select-layout -t "$COCKPIT_SESSION:work" "$COCKPIT_LAYOUT"
  fi
  # stamp pane (by stable pane_id) so the poller knows which transcript to watch
  $TMUX set -p -t "$pane" @session_id "$id"
  $TMUX set -p -t "$pane" @cwd "$cwd"
  $TMUX set -p -t "$pane" @label "${title:0:32}"
  $TMUX set -p -t "$pane" @badge "starting"
done
$TMUX select-layout -t "$COCKPIT_SESSION:work" "$COCKPIT_LAYOUT"

# second workspace: an empty 'scratch' window for quick / transient sessions.
# (Alt-n to drop a resumed session in, or Alt-N once new-session lands.)
$TMUX new-window -t "$COCKPIT_SESSION" -n scratch "bash -l"
$TMUX select-window -t "$COCKPIT_SESSION:work"

# launch the state poller against this server, in the background. Clear any
# straggler poller first and fully detach (setsid) so exactly one survives —
# multiple pollers fight over the borders (gray/blue flicker).
pkill -f "$HERE/cockpit-poller" 2>/dev/null || true
COCKPIT_TMUX="$TMUX" setsid nohup "$HERE/cockpit-poller" >/tmp/cockpit-poller.log 2>&1 &
exec $TMUX attach -t "$COCKPIT_SESSION"
