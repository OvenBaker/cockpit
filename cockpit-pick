#!/usr/bin/env bash
# cockpit-pick — interactive chooser over dormant Claude sessions.
# Plain numbered selection on a real tty. Three uses:
#
#   cockpit-pick startup           multi-select in the launching terminal;
#                                  prints chosen  id<TAB>cwd<TAB>title  to stdout
#                                  (UI is written to /dev/tty so stdout is clean)
#   cockpit-pick retarget <pane>   single-select; respawn <pane> onto the choice
#   cockpit-pick add               single-select; split a fresh pane, respawn it
#
# Why a popup, not display-menu, and bound DIRECTLY (not via run-shell)?
# Popups/menus need a client to draw on; `run-shell` has none (it returns 1),
# so the launcher binds  display-popup -E "cockpit-pick …"  straight to the key.
# A popup is a real pty, so this same numbered prompt works there too — no fzf
# dependency, no press-and-hold mouse menu.
set -uo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"; source "$HERE/lib.sh"
TMUX=${COCKPIT_TMUX:-"tmux -L cockpit"}
POOL="${COCKPIT_POOL:-40}"             # how many candidates to list
DEF_N="${COCKPIT_DEFAULT_N:-6}"        # default selection count (startup, empty input)
MODE="${1:-startup}"

say() { printf '%s\n' "$*" >/dev/tty; }
pause() { read -rsn1 -p "$1" </dev/tty || true; say ""; }

fmt_age() { local s=$1
  (( s < 3600 ))  && { printf '%dm' $((s/60));    return; }
  (( s < 86400 )) && { printf '%dh' $((s/3600));  return; }
  printf '%dd' $((s/86400)); }

# expand a selection string ("1 3 5-8", "a"/"all", commas ok) into 1-based indices
parse_sel() {
  local raw="${1//,/ }" tok lo hi x
  if [[ "$raw" =~ ^[Aa]([Ll][Ll])?$ ]]; then seq 1 "${#CAND[@]}"; return; fi
  for tok in $raw; do
    if [[ "$tok" =~ ^([0-9]+)-([0-9]+)$ ]]; then
      lo=${BASH_REMATCH[1]}; hi=${BASH_REMATCH[2]}
      (( lo <= hi )) && for ((x=lo; x<=hi; x++)); do echo "$x"; done
    elif [[ "$tok" =~ ^[0-9]+$ ]]; then echo "$tok"; fi
  done
}

# respawn a pane onto a chosen session and re-stamp it so the poller tracks it
retarget_pane() {
  local pane="$1" id="$2" cwd="$3" title="$4" agent="${5:-claude}"
  if session_is_running_agent "$agent" "$id"; then   # re-check at action time
    say "cockpit: $id is live elsewhere — not retargeting"; sleep 1; return 0
  fi
  local cmd; cmd=$(agent_resume_inner "$agent" "$id" "$cwd")
  $TMUX respawn-pane -k -t "$pane" "bash -lc $(printf %q "$cmd")"
  $TMUX set -p -t "$pane" @session_id "$id"
  $TMUX set -p -t "$pane" @cwd "$cwd"
  $TMUX set -p -t "$pane" @label "$title"     # full; border truncates to width
  $TMUX set -p -t "$pane" @agent "$agent"
  $TMUX set -p -t "$pane" @badge "starting"
}

# spawn a brand-NEW session (no resume) in <cwd> for <agent>, reusing a bare
# shell if the active pane is one, else splitting. No @session_id — the poller
# adopts the transcript once the agent writes it (cockpit_adopt_agent), via @born.
spawn_new() {
  local W="$1" cwd="$2" agent="${3:-claude}" cmd act actsid pane launch
  case "$agent" in codex) launch="exec codex";; *) launch="exec claude";; esac
  cmd="cd $(printf %q "$cwd") && $launch"
  act=$($TMUX display -p -t "$W" '#{pane_id}' 2>/dev/null)
  actsid=$($TMUX show -p -t "$act" @session_id 2>/dev/null | awk '{print $2}')
  if [[ -z "$actsid" && -n "$act" ]]; then
    pane="$act"; $TMUX respawn-pane -k -t "$pane" "bash -lc $(printf %q "$cmd")"
  else
    pane=$($TMUX split-window -t "$W" -P -F '#{pane_id}' "bash -lc $(printf %q "$cmd")" 2>/dev/null) \
      || { say "  no room for another pane at this width."; return 1; }
  fi
  $TMUX set -p -t "$pane" @session_id ""           # explicit: pending adoption
  $TMUX set -p -t "$pane" @cwd "$cwd"
  $TMUX set -p -t "$pane" @agent "$agent"
  $TMUX set -p -t "$pane" @born "$(date +%s)"
  $TMUX set -p -t "$pane" @label "new · $(basename "$cwd")"
  $TMUX set -p -t "$pane" @badge "starting"
  $TMUX select-layout -t "$W" "$COCKPIT_LAYOUT" 2>/dev/null
}

# new-session mode runs before the dormant-session gather (it needs cwds, not sessions)
if [[ "$MODE" == new ]]; then
  W=$(cockpit_cur_window)
  say ""
  say "  cockpit · new session"
  say "  ┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄"
  say "  agent?   [Enter = claude · c = codex]"
  printf '  > ' >/dev/tty; read -r ag </dev/tty || ag=""
  case "${ag,,}" in c|cx|codex) agent=codex;; *) agent=claude;; esac
  mapfile -t CWDS < <(cockpit_recent_cwds 15)
  say ""; say "  directory for the new $agent session:"
  i=0; for d in "${CWDS[@]}"; do i=$((i+1)); printf '  %2d  %s\n' "$i" "${d/#$HOME/\~}" >/dev/tty; done
  say ""
  say "  Pick a number, or type a path (~ ok).  Enter = cancel."
  printf '  > ' >/dev/tty
  read -r line </dev/tty || line=""
  [[ -n "${line// }" ]] || { say "  cancelled."; sleep 0.4; exit 0; }
  if [[ "$line" =~ ^[0-9]+$ ]] && (( line >= 1 && line <= ${#CWDS[@]} )); then
    target="${CWDS[$((line-1))]}"
  else
    target="${line/#\~/$HOME}"
  fi
  [[ -d "$target" ]] || { say "  not a directory: $target"; sleep 1; exit 0; }
  spawn_new "$W" "$target" "$agent" && { say "  → new $agent session in ${target/#$HOME/\~}"; sleep 0.5; }
  exit 0
fi

# --- gather + render ---------------------------------------------------------
mapfile -t CAND < <(cockpit_candidates "$POOL")
if (( ${#CAND[@]} == 0 )); then
  say "cockpit: no dormant sessions to choose from."
  [[ "$MODE" == startup ]] || pause "(any key to close) "
  exit 0
fi

say ""
say "  cockpit · dormant sessions  (cl=claude  cx=codex)"
say "  ┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄"
i=0
for row in "${CAND[@]}"; do
  IFS=$'\t' read -r id cwd title agent <<< "$row"; [[ -n "$agent" ]] || agent=claude
  i=$((i+1))
  jsonl=$(agent_transcript "$agent" "$id" "$cwd")
  age=$(fmt_age "$(idle_seconds "$jsonl")")
  tag=$([[ "$agent" == codex ]] && echo cx || echo cl)
  printf '  %2d  %s %4s  %-22s  %s\n' "$i" "$tag" "$age" "${cwd/#$HOME/\~}" "${title:0:44}" >/dev/tty
done
say ""

# --- act on the mode ---------------------------------------------------------
case "$MODE" in
  startup)
    n_def=$(( DEF_N < ${#CAND[@]} ? DEF_N : ${#CAND[@]} ))
    say "  Select panes to open:  e.g.  1 3 5-8   ·   a = all   ·   Enter = top $n_def"
    printf '  > ' >/dev/tty
    read -r line </dev/tty || line=""
    if [[ -z "${line// }" ]]; then mapfile -t idx < <(seq 1 "$n_def")
    else mapfile -t idx < <(parse_sel "$line"); fi
    declare -A seen
    for nsel in "${idx[@]}"; do
      (( nsel >= 1 && nsel <= ${#CAND[@]} )) || continue
      [[ -n "${seen[$nsel]:-}" ]] && continue; seen[$nsel]=1
      printf '%s\n' "${CAND[$((nsel-1))]}"          # → stdout, captured by launcher
    done
    ;;

  retarget)
    pane="${2:-}"
    # empty, or an unexpanded "#{pane_id}" → resolve the window's active pane
    # (unchanged by the keypress, so it's the pane the user pressed Alt-r on).
    [[ -z "$pane" || "$pane" == *'#{'* ]] && \
      pane=$($TMUX display -p -t "$COCKPIT_SESSION:0" '#{pane_id}' 2>/dev/null)
    say "  Retarget this pane → which session?"
    printf '  > ' >/dev/tty
    read -r line </dev/tty || line=""
    mapfile -t idx < <(parse_sel "$line"); nsel="${idx[0]:-}"
    [[ -n "$nsel" ]] && (( nsel >= 1 && nsel <= ${#CAND[@]} )) || { say "  cancelled."; sleep 0.6; exit 0; }
    IFS=$'\t' read -r id cwd title agent <<< "${CAND[$((nsel-1))]}"
    retarget_pane "$pane" "$id" "$cwd" "$title" "${agent:-claude}"
    say "  → ${title:0:50}"; sleep 0.6
    ;;

  add)
    W=$(cockpit_cur_window)   # add to the workspace you're viewing
    # If the active pane is a bare untracked shell (e.g. a fresh 'scratch'
    # workspace's placeholder), reuse it instead of splitting — otherwise split.
    act=$($TMUX display -p -t "$W" '#{pane_id}' 2>/dev/null)
    actsid=$($TMUX show -p -t "$act" @session_id 2>/dev/null | awk '{print $2}')
    split_made=0
    if [[ -z "$actsid" ]]; then
      pane="$act"                                            # reuse placeholder shell
    else
      pane=$($TMUX split-window -t "$W" -P -F '#{pane_id}' "bash -l" 2>/dev/null) \
        || { say "  no room for another pane at this width."; pause "(any key) "; exit 0; }
      split_made=1
      $TMUX select-layout -t "$W" "$COCKPIT_LAYOUT" 2>/dev/null
    fi
    say "  New pane → which session?"
    printf '  > ' >/dev/tty
    read -r line </dev/tty || line=""
    mapfile -t idx < <(parse_sel "$line"); nsel="${idx[0]:-}"
    if [[ -z "$nsel" ]] || ! (( nsel >= 1 && nsel <= ${#CAND[@]} )); then
      (( split_made )) && { $TMUX kill-pane -t "$pane" 2>/dev/null; $TMUX select-layout -t "$W" "$COCKPIT_LAYOUT" 2>/dev/null; }
      say "  cancelled."; sleep 0.6; exit 0      # reused placeholder is left as-is
    fi
    IFS=$'\t' read -r id cwd title agent <<< "${CAND[$((nsel-1))]}"
    retarget_pane "$pane" "$id" "$cwd" "$title" "${agent:-claude}"
    say "  → ${title:0:50}"; sleep 0.6
    ;;

  *) echo "usage: cockpit-pick {startup|retarget <pane>|add|new}" >&2; exit 2;;
esac
